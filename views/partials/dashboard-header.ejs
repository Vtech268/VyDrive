<header class="dashboard-header">
  <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
    <i class="fas fa-bars"></i>
  </button>

  <div class="header-search">
    <i class="fas fa-search"></i>
    <input type="text" placeholder="Cari sesuatu..." id="globalSearch" autocomplete="off">
  </div>

  <div class="header-actions">
    <a href="/file/upload" class="btn btn-primary btn-sm">
      <i class="fas fa-cloud-upload-alt"></i>
      <span>Upload</span>
    </a>

    <div class="header-divider"></div>

    <div class="header-user">
      <div class="header-avatar">
        <%= user ? user.username.charAt(0).toUpperCase() : 'G' %>
      </div>
      <div class="header-user-info">
        <span class="user-name"><%= user ? user.username : 'Guest' %></span>
        <span class="user-plan <%= user && user.plan === 'paid' ? 'plan-paid' : 'plan-free' %>">
          <%= user && user.plan === 'paid' ? 'PRO' : 'FREE' %>
        </span>
      </div>
    </div>
  </div>
</header>
