<header class="header">
  <div class="container">
    <div class="header-content">
      <!-- Logo -->
      <a href="/" class="logo">
        <i class="fas fa-cloud"></i>
        <span>VyDrive</span>
      </a>
      
      <!-- Mobile Menu Toggle -->
      <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
      
      <!-- Navigation -->
      <nav class="nav" id="mainNav">
        <ul class="nav-list">
          <li class="nav-item">
            <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">
              <i class="fas fa-home"></i> Home
            </a>
          </li>
          <li class="nav-item">
            <a href="/file/upload" class="nav-link <%= currentPath === '/file/upload' ? 'active' : '' %>">
              <i class="fas fa-upload"></i> Upload
            </a>
          </li>
          <li class="nav-item">
            <a href="/script/upload" class="nav-link <%= currentPath === '/script/upload' ? 'active' : '' %>">
              <i class="fas fa-table"></i> Sheet
            </a>
          </li>
          <li class="nav-item">
            <a href="/api-docs" class="nav-link <%= currentPath === '/api-docs' ? 'active' : '' %>">
              <i class="fas fa-code"></i> API
            </a>
          </li>
          <li class="nav-item">
            <a href="/pricing" class="nav-link <%= currentPath === '/pricing' ? 'active' : '' %>">
              <i class="fas fa-tags"></i> Pricing
            </a>
          </li>
          <li class="nav-item">
            <a href="/chat" class="nav-link <%= currentPath === '/chat' ? 'active' : '' %>">
              <i class="fas fa-comments"></i> Chat
            </a>
          </li>
          <% if (user) { %>
            <li class="nav-item">
              <a href="/dashboard" class="nav-link <%= currentPath.startsWith('/dashboard') ? 'active' : '' %>">
                <i class="fas fa-tachometer-alt"></i> Dashboard
              </a>
            </li>
            <% if (user.isAdmin) { %>
              <li class="nav-item">
                <a href="/admin" class="nav-link <%= currentPath.startsWith('/admin') ? 'active' : '' %>">
                  <i class="fas fa-cog"></i> Admin
                </a>
              </li>
            <% } %>
            <li class="nav-item">
              <a href="/auth/logout" class="nav-link">
                <i class="fas fa-sign-out-alt"></i> Logout
              </a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a href="/auth/login" class="nav-link nav-link-primary">
                <i class="fas fa-sign-in-alt"></i> Login
              </a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  </div>
</header>
