<% layout('/layouts/main') %>

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="gradient-text">VyDrive Cloud</span>
        <br>File Hosting & Database API
      </h1>
      <p class="hero-desc">
        Platform gratis untuk hosting file dan database API berbasis Google Drive & Google Sheets. 
        Mudah digunakan, cepat, dan handal untuk kebutuhan aplikasi Anda.
      </p>
      <div class="hero-actions">
        <a href="/file/upload" class="btn btn-primary btn-lg">
          <i class="fas fa-upload"></i> Upload File
        </a>
        <a href="/api-docs" class="btn btn-secondary btn-lg">
          <i class="fas fa-code"></i> API Docs
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-value">Unlimited</span>
          <span class="stat-label">File Uploads</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">Free</span>
          <span class="stat-label">Database API</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">24/7</span>
          <span class="stat-label">Support Chat</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="features">
  <div class="container">
    <h2 class="section-title">Fitur Utama</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-cloud-upload-alt"></i>
        </div>
        <h3 class="feature-title">VyDrive</h3>
        <p class="feature-desc">
          Upload file gratis ke Google Drive dengan link langsung. 
          Support semua jenis file dengan pilihan expired otomatis.
        </p>
        <a href="/file/upload" class="feature-link">
          Upload Sekarang <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon feature-icon-purple">
          <i class="fas fa-database"></i>
        </div>
        <h3 class="feature-title">VyDB</h3>
        <p class="feature-desc">
          Database API gratis berbasis Google Spreadsheet. 
          REST API sederhana untuk CRUD operations.
        </p>
        <a href="/api-docs" class="feature-link">
          Lihat Dokumentasi <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon feature-icon-green">
          <i class="fas fa-comments"></i>
        </div>
        <h3 class="feature-title">Live Chat</h3>
        <p class="feature-desc">
          Chat langsung dengan admin untuk bantuan teknis. 
          Tersedia 24/7 untuk membantu Anda.
        </p>
        <a href="/chat" class="feature-link">
          Mulai Chat <i class="fas fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="how-it-works">
  <div class="container">
    <h2 class="section-title">Cara Penggunaan</h2>
    <div class="steps">
      <div class="step">
        <div class="step-number">1</div>
        <h4 class="step-title">Upload File</h4>
        <p class="step-desc">Pilih file dan upload ke VyDrive Cloud</p>
      </div>
      <div class="step-arrow"><i class="fas fa-arrow-right"></i></div>
      <div class="step">
        <div class="step-number">2</div>
        <h4 class="step-title">Dapatkan Link</h4>
        <p class="step-desc">Copy link download yang dihasilkan</p>
      </div>
      <div class="step-arrow"><i class="fas fa-arrow-right"></i></div>
      <div class="step">
        <div class="step-number">3</div>
        <h4 class="step-title">Bagikan</h4>
        <p class="step-desc">Bagikan link ke siapa saja</p>
      </div>
    </div>
  </div>
</section>

<section class="cta">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">Siap untuk memulai?</h2>
      <p class="cta-desc">
        Daftar gratis dan dapatkan akses ke semua fitur VyDrive Cloud.
      </p>
      <div class="cta-actions">
        <a href="/auth/register" class="btn btn-primary btn-lg">
          <i class="fas fa-user-plus"></i> Daftar Gratis
        </a>
        <a href="/pricing" class="btn btn-outline btn-lg">
          <i class="fas fa-tags"></i> Lihat Harga
        </a>
      </div>
    </div>
  </div>
</section>
