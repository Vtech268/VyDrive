<% layout('/layouts/dashboard') %>

<div class="dashboard-header-section">
  <h1 class="page-title"><i class="fas fa-list-alt"></i> API Logs</h1>
  <p class="page-subtitle">Log request API VyDB</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-warning">
  <i class="fas fa-exclamation-triangle"></i> <strong>Catatan:</strong> Google Sheets API belum aktif — log akan tersedia setelah API diaktifkan.
  <br><small><%= error %></small>
</div>
<% } %>

<div class="dashboard-section">
  <h2 class="section-title"><i class="fas fa-history"></i> Log Terbaru (<%= logs.length %>)</h2>

  <% if (logs && logs.length > 0) { %>
  <div class="table-responsive">
    <table class="file-table">
      <thead>
        <tr>
          <th>Waktu</th>
          <th>API Key</th>
          <th>Endpoint</th>
          <th>Method</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% logs.forEach(function(log) { %>
        <tr>
          <td><small><%= log.timestamp ? new Date(log.timestamp).toLocaleString('id-ID') : '-' %></small></td>
          <td><small><code><%= log.apiKey ? log.apiKey.substring(0, 16) + '...' : '-' %></code></small></td>
          <td><small><%= log.endpoint || '-' %></small></td>
          <td>
            <span class="badge <%= log.method === 'GET' ? 'badge-default' : 'badge-success' %>">
              <%= log.method || '-' %>
            </span>
          </td>
          <td>
            <span class="badge <%= log.status >= 400 ? 'badge-danger' : 'badge-success' %>">
              <%= log.status || '-' %>
            </span>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="empty-state">
    <i class="fas fa-file-alt fa-3x" style="color:var(--text-muted);margin-bottom:1rem;"></i>
    <p class="text-muted">Belum ada log API</p>
    <small class="text-muted">Log akan muncul setelah ada request ke VyDB API.</small>
  </div>
  <% } %>
</div>
